# Elapas API — Variables de Entorno

# Copiar este archivo como .env y completar los valores reales:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Base de Datos
# ──────────────────────────────────────────────

# URL de conexión a PostgreSQL.
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# Ejemplo local: postgresql://postgres@localhost:5432/elapas
# Ejemplo con contraseña: postgresql://postgres:mipassword@localhost:5432/elapas
DATABASE_URL=postgresql://postgres@localhost:5432/elapas

# ──────────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────────

# Puerto donde escucha la API. Por defecto 3000 si no se define.
PORT=3000

# ──────────────────────────────────────────────
# Better Auth — Autenticación
# ──────────────────────────────────────────────

# Clave secreta para firmar tokens de sesión y cookies.
# En producción usar una cadena aleatoria de al menos 32 caracteres.
# Generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=super-secret-change-in-production

# URL base de la API, usada por Better Auth para generar URLs de callback
# y redirecciones. Debe coincidir con la URL pública de la API.
# - Desarrollo: http://localhost:3000
# - Producción: https://api.elapas.bo (ejemplo)
BETTER_AUTH_URL=http://localhost:3000
